OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-5.6-luna
OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_STT_LANGUAGE=pt
OPENAI_STT_PROMPT="O áudio está em português europeu (pt-PT)."
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
OPENAI_TTS_INSTRUCTIONS="Fala em português europeu, de forma clara e natural."
OPENAI_REASONING_EFFORT=none
OPENAI_MAX_OUTPUT_TOKENS=300
MICROPHONE_INDEX=
LISTEN_TIMEOUT_SECONDS=5
PHRASE_TIME_LIMIT_SECONDS=10
CONVERSATION_HISTORY_TURNS=10
MAX_WEB_CONVERSATIONS=100
VOICE_REQUESTS_PER_MINUTE=20
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
POCKET_ASSISTANT_ALLOWED_ORIGINS=
# AUDIO_PLAYER=aplay
